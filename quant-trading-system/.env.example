# 量化交易系统环境变量配置
# 复制此文件为 .env 并根据实际情况修改

# ==================== 应用配置 ====================
APP_NAME=quant-trading-system
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=your-secret-key-change-in-production
APP_URL=http://localhost:8000

# ==================== 数据库配置 ====================
# MySQL 主数据库
DB_HOST=8.130.110.224
DB_PORT=3306
DB_NAME=quant_trading
DB_USER=root
DB_PASSWORD=Zz12510039.
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# Redis 缓存
REDIS_HOST=8.130.110.224
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ClickHouse 时序数据库
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your-clickhouse-password
CLICKHOUSE_DATABASE=quant_data

# ==================== 消息队列 ====================
# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=quant-trading-group
KAFKA_AUTO_OFFSET_RESET=latest

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# ==================== 数据源配置 ====================
# Baostock
BAOSTOCK_USERNAME=your-baostock-username
BAOSTOCK_PASSWORD=your-baostock-password

# Tushare
TUSHARE_TOKEN=your-tushare-token
TUSHARE_PRO_TOKEN=your-tushare-pro-token

# 东方财富
EASTMONEY_TOKEN=your-eastmoney-token

# ==================== 安全配置 ====================
# JWT 配置
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# 加密密钥
ENCRYPTION_KEY=your-encryption-key-32-bytes

# ==================== 监控配置 ====================
# Prometheus
PROMETHEUS_METRICS_PORT=8001

# OpenTelemetry
OTEL_SERVICE_NAME=quant-trading-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ==================== 前端配置 ====================
FRONTEND_URL=http://localhost:3000
FRONTEND_API_URL=http://localhost:8000/api/v1

# ==================== 邮件配置 ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=no-reply@your-org.com

# ==================== 文件存储 ====================
# 本地存储
STORAGE_PATH=./storage

# S3 存储 (可选)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=quant-trading-storage
AWS_REGION=us-east-1

# ==================== 第三方服务 ====================
# 短信服务
SMS_API_KEY=your-sms-api-key
SMS_API_SECRET=your-sms-api-secret

# 推送服务
PUSH_API_KEY=your-push-api-key

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=./logs/app.log

# ==================== 性能配置 ====================
WORKER_COUNT=4
MAX_REQUESTS=1000
REQUEST_TIMEOUT=30

# ==================== 测试配置 ====================
TEST_DB_NAME=quant_trading_test
TEST_REDIS_DB=15

# ==================== 开发工具 ====================
# 仅在开发环境启用
ENABLE_SWAGGER=true
ENABLE_DEBUG_TOOLBAR=true
ENABLE_SQL_LOGGING=true